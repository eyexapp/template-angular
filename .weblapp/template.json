{
  "name": "angular",
  "displayName": "Angular",
  "description": "Production-ready Angular 21+ template with standalone components, NgRx Signal Store, Tailwind CSS 4, and i18n",
  "category": "frontend",
  "language": "typescript",
  "framework": "angular",
  "stack": ["angular", "typescript", "tailwindcss", "ngrx-signals", "vitest", "ngx-translate"],
  "features": ["standalone-components", "signal-store", "lazy-routing", "i18n", "dark-mode", "auth-guard", "interceptors"],
  "commands": {
    "dev": "npm start",
    "build": "npm run build",
    "test": "npm test",
    "lint": "npm run lint"
  },
  "packageManager": "npm",
  "ci": {
    "workflowTemplate": "angular",
    "runner": "ubuntu-latest",
    "runtime": {
      "name": "node",
      "version": "20",
      "setup": "actions/setup-node@v4",
      "cache": "npm"
    },
    "services": {},
    "steps": {
      "install": "npm ci",
      "build": "npm run build",
      "test": "npm test",
      "lint": "npm run lint"
    }
  }
}
